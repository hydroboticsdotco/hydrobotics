{
  "expo": {
    "name": "Hydro",
    "slug": "hydro-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hydroapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#060B14",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "co.hydrobotics.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.hydrobotics.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A2438",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#060B14",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Hydro uses the camera to record real-world task videos you choose to contribute.",
          "microphonePermission": "Hydro records audio together with your task videos.",
          "recordAudioAndroid": true
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b06fbcab-0917-4931-a18a-9d8b89baaf06"
      }
    },
    "owner": "hydroboticss-team"
  }
}
