# Copy to .env and fill in your own values.
# Values prefixed EXPO_PUBLIC_ are bundled into the app and are safe to expose.

# --- Supabase (Project Settings → API) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Privy (dashboard.privy.io → your app) ---
# Used for email OTP login + embedded wallets.
EXPO_PUBLIC_PRIVY_APP_ID=YOUR-PRIVY-APP-ID
EXPO_PUBLIC_PRIVY_CLIENT_ID=YOUR-PRIVY-CLIENT-ID

# ---------------------------------------------------------------------------
# SERVER-SIDE SECRETS — do NOT put these here or anywhere in the app bundle.
# Set them on the Supabase Edge Function with `supabase secrets set ...`:
#
#   OPENAI_API_KEY         # required: AI video review (gpt-4o-mini vision)
#
# Optional (only when enabling on-chain rewards; MVP1 is off-chain):
#   BASE_RPC_URL
#   HYDRO_TOKEN_ADDRESS
#   TREASURY_PRIVATE_KEY
#   HYDRO_DECIMALS=18
# ---------------------------------------------------------------------------
