# Copy to .env and fill in. Values prefixed EXPO_PUBLIC_ are bundled into the app.

# --- Supabase (Project Settings → API) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- WalletConnect / Reown (cloud.reown.com) ---
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR-PROJECT-ID

# NOTE: The following are SERVER-SIDE secrets for the reward Edge Function.
# Do NOT put them here / in the app. Set them with:
#   supabase secrets set BASE_RPC_URL=... HYDRO_TOKEN_ADDRESS=... TREASURY_PRIVATE_KEY=... HYDRO_DECIMALS=18
